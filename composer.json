{
    "name": "k2gl/entity-exist",
    "description": "Symfony validation constraint that asserts a matching database row exists (or does not), via Doctrine.",
    "license": "MIT",
    "type": "symfony-bundle",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "doctrine/orm": "^2.13|^3.0",
        "symfony/validator": "^6.1|^7.0|^8.0",
        "symfony/dependency-injection": "^6.1|^7.0|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "symfony/phpunit-bridge": "^6.1|^7.0|^8.0",
        "symfony/var-dumper": "^6.1|^7.0|^8.0",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "~1.20.0",
        "rector/rector": "^2.0",
        "roave/security-advisories": "dev-latest",
        "k2gl/phpunit-fluent-assertions": "^12"
    },
    "autoload": {
        "psr-4": {
            "K2gl\\Component\\Validator\\Constraint\\EntityExist\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "K2gl\\Component\\Validator\\Constraint\\EntityExist\\Test\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs": "pint --test",
        "cs-fix": "pint",
        "check": [
            "@test",
            "@phpstan",
            "@cs"
        ]
    },
    "support": {
        "issues": "https://github.com/k2gl/entity-exist/issues",
        "source": "https://github.com/k2gl/entity-exist"
    },
    "authors": [
        {
            "name": "Nickolay Harin",
            "email": "l0gic@ya.ru"
        }
    ]
}
